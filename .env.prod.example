# ============================================
# Production Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# Application
NODE_ENV=production
PORT=3001
DB_PATH=/app/data/app.db

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# JWT Secret (generate a random string)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Docker Image (Aliyun ACR)
DOCKER_REGISTRY=crpi-yl4pb9sg5y2myg6f.cn-hangzhou.personal.cr.aliyuncs.com
DOCKER_IMAGE_NAME=9992099/change_number_system

# Watchtower (optional - for auto-update)
WATCHTOWER_NOTIFICATIONS=slack
# WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=https://hooks.slack.com/...
